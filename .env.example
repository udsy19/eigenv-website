# --- Backend (Notion + Resend). Without these the form falls back to a mailto. ---

# Notion integration token (secret_… ) and the target database id.
# The database needs these properties: Name (title), Email (email), Role (text),
# Company (text), Timing (text), Looking to (multi-select), Link (url),
# Attachment (files). Share the database with your integration.
NOTION_TOKEN=
NOTION_DATABASE_ID=
# Visit-analytics database (cookieless). Omit to disable tracking.
NOTION_VISITORS_DATABASE_ID=

# Resend — sends the confirmation email. Verify a domain and set a sender on it.
RESEND_API_KEY=
RESEND_FROM="EIGENV <ada@eigenv.ai>"

# Optional: also send an internal notification of each enquiry here.
ALERT_TO=ada@eigenv.ai

# Optional: B2B company identification from IP (ipinfo.io). Org-level only.
IPINFO_TOKEN=
